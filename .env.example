# ────────────────────────────────────────────────────────────────────
# KickrIQ environment variables
# Copy to .env (dev) or paste into Vercel/Railway dashboards (prod).
# ────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────
# VITE_* values are exposed to the browser — only put public-safe values here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Server-only — service role key, NEVER expose to the client.
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic (server-only) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (server-only) ────────────────────────────────────────────
# Use test keys (sk_test_...) in dev, live keys (sk_live_...) in prod.
# Optional for v1 launch — leave as placeholder until Pro tier ships.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx

# ── Google OAuth / Gmail (server-only) ──────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx
# In prod set this to https://api.kickriq.com/api/gmail/callback
# (must exactly match the redirect URI configured in Google Cloud Console)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# ── Analytics (PostHog, optional) ───────────────────────────────────
# Get the project API key at posthog.com → Project Settings.
# Leave unset in dev to no-op all analytics calls.
VITE_POSTHOG_KEY=
# Default us.i.posthog.com — set to https://eu.i.posthog.com if EU project.
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Hosting ─────────────────────────────────────────────────────────
# Frontend origin — used for CORS allow-list on the API server.
# In prod set to https://kickriq.com (the public site URL).
CLIENT_URL=http://localhost:5173

# Public canonical base URL — used by sitemap.xml so search engines see
# https://kickriq.com/... regardless of which host actually generated it.
# Leave unset in dev. In prod set to https://kickriq.com.
# PUBLIC_BASE_URL=https://kickriq.com

# Port the Express API listens on. Railway/Render/Fly inject PORT
# automatically — don't set it manually in those environments.
# PORT=3001

# ── Resend (server-only) ───────────────────────────────────────────────────
# Transactional email — coach digest and per-event notifications.
# Sign up at resend.com, free tier is 3000/month.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=KickrIQ Coach <coaches@kickriq.com>

# Daily digest cron — shared secret for the GitHub Action callback.
# Generate with: openssl rand -hex 24
# COACH_DIGEST_SECRET=
